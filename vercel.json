{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron?phase=morning",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron?phase=night",
      "schedule": "0 19 * * *"
    }
  ]
}